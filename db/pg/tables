psql -d "${DB:?DB env var required}" -c "SELECT tablename, pg_size_pretty(pg_total_relation_size(quote_ident(tablename))) AS total_size, pg_size_pretty(pg_relation_size(quote_ident(tablename))) AS table_size FROM pg_tables WHERE schemaname='public' ORDER BY pg_total_relation_size(quote_ident(tablename)) DESC LIMIT 20;"
